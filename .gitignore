# ─────────────────────────────────────────────────────────────
# My Agent System — .gitignore
# Stack: Python · Poetry · LangChain/LangGraph · FastAPI
#         ChromaDB · Redis · LangFuse · SQLite
# ─────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════
# 🔑 환경 변수 & 시크릿 (절대 커밋 금지)
# ══════════════════════════════════════════════════════════════
.env
.env.local
.env.production
.env.staging
.env.development
# .env.example 은 커밋 허용 (위 패턴에 포함되지 않음)
*.pem
*.key
*.p12
secrets/


# ══════════════════════════════════════════════════════════════
# 🐍 Python 런타임
# ══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so

# 배포 패키징
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
share/python-wheels/

# 타입 스텁
*.pyi  # 자동 생성된 것만 (직접 작성한 것은 제외하려면 개별 관리)


# ══════════════════════════════════════════════════════════════
# 📦 Poetry (의존성 관리)
# ══════════════════════════════════════════════════════════════
# poetry.lock은 커밋 권장 (재현 가능한 빌드)
# poetry.lock  ← 주석 처리 = 커밋함

# 가상환경 (Poetry가 프로젝트 내에 생성한 경우)
.venv/
venv/
env/
ENV/
.virtualenv/


# ══════════════════════════════════════════════════════════════
# 🧪 테스트 & 코드 품질
# ══════════════════════════════════════════════════════════════
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Ruff 캐시
.ruff_cache/

# Mypy 캐시
.mypy_cache/
.dmypy.json
dmypy.json

# pytest 임시 파일
pytest-of-*/


# ══════════════════════════════════════════════════════════════
# 🗄️ 데이터베이스 & 스토리지
# ══════════════════════════════════════════════════════════════

# SQLite (LangGraph Checkpointer — HITL 세션 상태)
*.db
*.sqlite
*.sqlite3
checkpoints.db
langgraph_checkpoints.db

# ChromaDB (Episodic Memory + Tool Registry)
chroma_db/
chromadb/
.chroma/
chroma_data/

# 벡터 DB 인덱스 (로컬 실험용)
faiss_index/
*.faiss
*.pkl           # 직렬화된 임베딩


# ══════════════════════════════════════════════════════════════
# 📊 LangFuse & 관찰 가능성
# ══════════════════════════════════════════════════════════════
# LangFuse는 클라우드 서비스 — 로컬 로그만 제외
langfuse_local/
traces/
*.trace.json


# ══════════════════════════════════════════════════════════════
# 🧠 AI & LLM 관련
# ══════════════════════════════════════════════════════════════
